{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["scope_mode", "categories"],
  "properties": {
    "scope_mode": {"enum": ["single_category", "multi_category"]},
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category_id", "mention_phrases", "is_primary"],
        "properties": {
          "category_id": {"type": "string", "minLength": 1},
          "mention_phrases": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "is_primary": {"type": "boolean"}
        }
      }
    }
  }
}
