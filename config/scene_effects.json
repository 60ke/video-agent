{
  "schema_version": 1,
  "scenes": {
    "site_home": {
      "template": "ui_feature_entry",
      "motion": "spring_card_pop",
      "transition": {"kind": "crossfade", "duration_frames": 6},
      "sfx": null
    },
    "feature_entry": {
      "template": "ui_feature_entry",
      "motion": "detail_push_in",
      "transition": {"kind": "crossfade", "duration_frames": 6},
      "sfx": "mouse_click"
    },
    "parameter_input": {
      "template": "ui_params_focus",
      "motion": "scale_in",
      "transition": {"kind": "crossfade", "duration_frames": 6},
      "sfx": "mouse_click",
      "callout_reveal_frames": 10
    },
    "result_gallery": {
      "template": "result_showcase",
      "motion": "slide_gallery",
      "transition": {"kind": "slide_left", "duration_frames": 8},
      "sfx": "swish",
      "subtitle_style": "gallery_yellow"
    },
    "result_gallery_summary": {
      "template": "result_showcase",
      "motion": "card_stack",
      "transition": {"kind": "slide_left", "duration_frames": 8},
      "sfx": "swish"
    },
    "result_detail": {
      "template": "result_showcase",
      "sfx": "swish"
    },
    "editor_workspace": {
      "template": "ui_feature_entry",
      "motion": "fade_in",
      "transition": {"kind": "crossfade", "duration_frames": 6},
      "sfx": null
    },
    "editor_before_after": {
      "template": "reference_to_result",
      "motion": "before_after",
      "transition": {"kind": "crossfade", "duration_frames": 6},
      "sfx": "transition_whoosh"
    },
    "reference_to_result": {
      "template": "reference_to_result",
      "motion": "before_after",
      "transition": {"kind": "crossfade", "duration_frames": 6},
      "sfx": "transition_whoosh"
    },
    "result_to_flat_plan": {
      "template": "reference_to_result",
      "motion": "before_after",
      "transition": {"kind": "crossfade", "duration_frames": 6},
      "sfx": "transition_whoosh"
    },
    "brand_closing": {
      "template": "ui_feature_entry",
      "motion": "light_sweep",
      "transition": {"kind": "crossfade", "duration_frames": 6},
      "sfx": null
    },
    "light_sweep_fallback": {
      "template": "result_showcase",
      "motion": "light_sweep",
      "transition": {"kind": "crossfade", "duration_frames": 6},
      "sfx": null
    }
  }
}
