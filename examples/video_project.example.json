{
  "schema_version": 1,
  "meta": {
    "case_id": "example_vi_design",
    "title": "VI设计功能种草",
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "target_platform": "douyin",
    "target_duration": 25,
    "language": "zh-CN",
    "safe_area": {
      "top": 120,
      "bottom": 260,
      "left": 60,
      "right": 60
    }
  },
  "inputs": {
    "target_url": null,
    "video_goal": "功能种草",
    "preferred_features": ["VI设计"],
    "brand_profile": "柯幻熊猫",
    "dependency_mode": {
      "browser": "kimi_webbridge",
      "renderer": "hyperframes",
      "asr": "funasr",
      "tts": "voice_clone_api"
    }
  },
  "assets": [
    {
      "id": "asset_001",
      "type": "image",
      "source": "assets/example_ui.png",
      "origin": "static_material_folder",
      "role": "ui_upload_form",
      "description": "功能页面截图，展示上传、选择类型和开始生成入口。",
      "visible_text": ["上传", "开始生成"],
      "supported_claims": ["选择参数后一键生成"],
      "quality": {
        "readable": true,
        "contains_private_info": false,
        "needs_review": false
      }
    }
  ],
  "script_segments": [
    {
      "id": "seg_001",
      "stage": "hook",
      "text": "做一套品牌视觉，不用从零开始。",
      "feature_id": "vi_design",
      "visual_intent": "show_feature_entry",
      "material_task": "show_ui_or_result",
      "keywords": ["品牌视觉", "不用从零开始"],
      "duration_hint": 3.2,
      "allow_rewrite": true
    }
  ],
  "voice_track": {
    "mode": "voice_clone",
    "engine": "voice_clone_api",
    "source_text": "做一套品牌视觉，不用从零开始。",
    "audio_path": "audio/voice.wav",
    "duration": 3.2,
    "speed_policy": {
      "minimum_units_per_second": 6.0
    },
    "high_risk_terms": ["柯幻熊猫", "AI"],
    "qa": {
      "brand_terms_recognized": true,
      "internal_silence_ok": true,
      "needs_regeneration": false
    }
  },
  "subtitle_track": {
    "source": "output/funasr/funasr_alignment.json",
    "format": "asr_aligned_segments",
    "segments": [
      {
        "id": "sub_001",
        "script_segment_id": "seg_001",
        "text": "做一套品牌视觉，不用从零开始。",
        "start": 0,
        "end": 3.2
      }
    ]
  },
  "visual_track": [
    {
      "id": "vis_001",
      "script_segment_ids": ["seg_001"],
      "start": 0,
      "end": 3.2,
      "asset_ids": ["asset_001"],
      "layout": "ui_operation_focus",
      "display_mode": "crop-focus",
      "framing": {
        "focus_region": "primary_action_area",
        "subject_min_frame_ratio": 0.45,
        "subtitle_safe": true
      },
      "motion": {
        "name": "stable_focus_with_callout",
        "avoid_flicker": true
      },
      "qa_expectations": {
        "no_black_frame": true,
        "no_flash_if_same_asset": true,
        "readable_ui": true,
        "no_meaningless_empty_panel": true
      }
    }
  ],
  "overlay_track": [],
  "audio_tracks": [],
  "ending_track": {
    "id": "default_panda_outro",
    "type": "video",
    "policy": "default",
    "source": "assets/outro/default_panda_outro.mp4",
    "start_policy": "after_main_video",
    "participates_in_script": false,
    "participates_in_subtitles": false,
    "preserve_audio": true,
    "duration": 3.436009
  },
  "renderer_plan": {
    "renderer": "hyperframes",
    "composition_dir": "hyperframes",
    "main_output": "output/versions/main.mp4",
    "final_output": "output/versions/final.mp4",
    "allow_creative_layout": true,
    "must_follow_tracks": true
  },
  "qa_rules": {
    "voice": {
      "require_asr_alignment": true,
      "require_brand_term_check": true,
      "max_internal_silence_seconds": 0.12
    },
    "visual": {
      "no_black_frames": true,
      "no_unexplained_blanks": true,
      "min_subject_frame_ratio": 0.35,
      "ui_must_be_readable": true,
      "subtitle_must_not_cover_key_content": true
    },
    "layout": {
      "dual_panel_height_must_match_media": true,
      "wide_ui_requires_crop_or_capture_if_unreadable": true,
      "same_asset_continuity_no_flash": true
    }
  }
}
