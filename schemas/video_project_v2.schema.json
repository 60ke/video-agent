{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video-agent.local/schemas/video_project_v2.schema.json",
  "title": "Video Agent Project V2",
  "description": "Render-ready multi-track video project for material-library driven vertical videos. Browser recordings and local crop-focus camera moves are intentionally excluded from this schema.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "meta",
    "assets",
    "script_segments",
    "voice_track",
    "subtitle_track",
    "visual_track",
    "overlay_track",
    "audio_tracks",
    "ending_track",
    "qa_rules"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "material_libraries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/material_library_ref"
      },
      "default": []
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/project_asset"
      }
    },
    "script_segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/script_segment"
      }
    },
    "voice_track": {
      "$ref": "#/$defs/voice_track"
    },
    "subtitle_track": {
      "$ref": "#/$defs/subtitle_track"
    },
    "visual_track": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/visual_clip"
      }
    },
    "overlay_track": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/overlay_clip"
      },
      "default": []
    },
    "audio_tracks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/audio_track"
      },
      "default": []
    },
    "ending_track": {
      "$ref": "#/$defs/ending_track"
    },
    "qa_rules": {
      "$ref": "#/$defs/qa_rules"
    }
  },
  "$defs": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "title", "width", "height", "fps", "platform", "video_type", "language"],
      "properties": {
        "case_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "width": {
          "const": 1080
        },
        "height": {
          "const": 1920
        },
        "fps": {
          "type": "integer",
          "enum": [24, 25, 30, 50, 60]
        },
        "platform": {
          "enum": ["douyin", "kuaishou", "reels", "shorts", "internal_review"]
        },
        "video_type": {
          "enum": ["single_feature_seed", "multi_feature_collection", "industry_vertical", "website_intro", "custom"]
        },
        "language": {
          "enum": ["zh-CN"]
        },
        "target_duration": {
          "type": "number",
          "minimum": 1
        },
        "safe_area": {
          "$ref": "#/$defs/safe_area"
        }
      }
    },
    "material_library_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["library_id", "manifest_path"],
      "properties": {
        "library_id": {
          "type": "string"
        },
        "manifest_path": {
          "type": "string"
        },
        "groups_path": {
          "type": "string"
        }
      }
    },
    "project_asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "source", "asset_kind", "visual_state", "display_rule", "truth"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "type": {
          "const": "image"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "filename": {
          "type": "string"
        },
        "asset_kind": {
          "enum": [
            "site_home",
            "feature_entry",
            "feature_menu",
            "feature_route_page",
            "feature_form_params",
            "generate_callout",
            "generating_state",
            "result_page_evidence",
            "result_image",
            "case_image",
            "gpt_keyframe",
            "cover_candidate"
          ]
        },
        "visual_state": {
          "enum": ["clean", "callout", "gpt_9x16", "prepared_9x16"]
        },
        "module": {
          "type": "string"
        },
        "module_label": {
          "type": "string"
        },
        "industry": {
          "type": "string"
        },
        "industry_label": {
          "type": "string"
        },
        "display_rule": {
          "$ref": "#/$defs/display_rule"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "claims": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "truth": {
          "$ref": "#/$defs/truth"
        },
        "source_material_asset_id": {
          "type": "string"
        },
        "quality": {
          "$ref": "#/$defs/quality"
        }
      }
    },
    "script_segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "stage", "text", "visual_intent", "evidence_binding", "duration_hint"],
      "properties": {
        "id": {
          "type": "string"
        },
        "stage": {
          "enum": ["hook", "site_intro", "feature_entry", "feature_demo", "result_showcase", "industry_showcase", "summary", "cta", "custom"]
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "camera_note": {
          "type": "string"
        },
        "visual_intent": {
          "enum": ["show_result_quality", "show_entry_path", "show_function_params", "show_multi_results", "show_site_value", "show_cta", "custom"]
        },
        "evidence_binding": {
          "enum": ["real_screenshot", "real_result", "case_result", "site_material", "evidence_cover", "packaging_only"]
        },
        "preferred_group_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "preferred_asset_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "duration_hint": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "voice_track": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "audio_path", "duration", "source_text"],
      "properties": {
        "engine": {
          "const": "minimax_t2a"
        },
        "audio_path": {
          "type": "string"
        },
        "duration": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "source_text": {
          "type": "string"
        },
        "speed": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 2
        }
      }
    },
    "subtitle_track": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "format", "segments"],
      "properties": {
        "source": {
          "type": "string"
        },
        "format": {
          "enum": ["minimax_word_aligned_reviewed_text", "manual_reviewed_text"]
        },
        "segments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/subtitle_segment"
          }
        }
      }
    },
    "subtitle_segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["script_segment_id", "start", "end", "text"],
      "properties": {
        "script_segment_id": {
          "type": "string"
        },
        "start": {
          "type": "number",
          "minimum": 0
        },
        "end": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "text": {
          "type": "string"
        }
      }
    },
    "visual_clip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "start",
        "end",
        "clip_type",
        "asset_ids",
        "display_rule",
        "motion",
        "transition_in",
        "script_segment_ids",
        "semantic_binding"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "start": {
          "type": "number",
          "minimum": 0
        },
        "end": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "clip_type": {
          "$ref": "#/$defs/clip_type"
        },
        "asset_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "group_id": {
          "type": "string"
        },
        "display_rule": {
          "$ref": "#/$defs/display_rule"
        },
        "sequence": {
          "$ref": "#/$defs/sequence"
        },
        "grid": {
          "$ref": "#/$defs/grid"
        },
        "motion": {
          "$ref": "#/$defs/motion"
        },
        "transition_in": {
          "$ref": "#/$defs/transition"
        },
        "script_segment_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "semantic_binding": {
          "$ref": "#/$defs/semantic_binding"
        },
        "qa_expectations": {
          "$ref": "#/$defs/visual_qa_expectations"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "clip_type": {
                "enum": ["image_sequence", "site_flow_steps", "result_gallery"]
              }
            }
          },
          "then": {
            "required": ["sequence"],
            "properties": {
              "asset_ids": {
                "minItems": 2
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "clip_type": {
                "const": "image_grid"
              }
            }
          },
          "then": {
            "required": ["grid"],
            "properties": {
              "asset_ids": {
                "minItems": 2
              }
            }
          }
        }
      ]
    },
    "clip_type": {
      "enum": [
        "image",
        "image_sequence",
        "image_grid",
        "site_flow_steps",
        "result_gallery",
        "before_after",
        "cover_frame"
      ]
    },
    "display_rule": {
      "enum": [
        "prepared_9x16",
        "portrait_full_width",
        "landscape_full_width_center",
        "grid_showcase",
        "split_compare"
      ]
    },
    "sequence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "min_item_duration", "max_item_duration", "transition"],
      "properties": {
        "mode": {
          "enum": ["quick_cut", "step_cut", "slide_sequence", "result_carousel"]
        },
        "min_item_duration": {
          "type": "number",
          "minimum": 0.7
        },
        "max_item_duration": {
          "type": "number",
          "minimum": 0.7
        },
        "transition": {
          "enum": ["quick_cut", "slide_left", "slide_right", "crossfade"]
        }
      }
    },
    "grid": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columns", "rows"],
      "properties": {
        "columns": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "rows": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "then_single": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "motion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "amount"],
      "properties": {
        "name": {
          "enum": [
            "hold",
            "whole_frame_push_in",
            "whole_frame_pull_out",
            "slide_left",
            "slide_right",
            "slide_up",
            "slide_down",
            "fade",
            "vertical_pan_for_tall_image",
            "grid_to_single",
            "single_to_grid"
          ]
        },
        "amount": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.08
        },
        "anchor": {
          "const": "center"
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "duration"],
      "properties": {
        "name": {
          "enum": ["cut", "crossfade"]
        },
        "duration": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.6
        }
      }
    },
    "semantic_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visual_subject", "required_asset_kinds"],
      "properties": {
        "visual_subject": {
          "type": "string"
        },
        "module": {
          "type": "string"
        },
        "module_label": {
          "type": "string"
        },
        "industry": {
          "type": "string"
        },
        "required_asset_kinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "site_home",
              "feature_entry",
              "feature_menu",
              "feature_route_page",
              "feature_form_params",
              "generate_callout",
              "generating_state",
              "result_page_evidence",
              "result_image",
              "case_image",
              "gpt_keyframe",
              "cover_candidate"
            ]
          },
          "uniqueItems": true
        },
        "result_claim_allowed": {
          "type": "boolean"
        }
      }
    },
    "overlay_clip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "start", "end", "type", "target_visual_id"],
      "properties": {
        "id": {
          "type": "string"
        },
        "start": {
          "type": "number",
          "minimum": 0
        },
        "end": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "type": {
          "enum": ["highlight_box", "arrow_callout", "pulse_ring", "label_tag"]
        },
        "target_visual_id": {
          "type": "string"
        },
        "box": {
          "$ref": "#/$defs/normalized_box"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "audio_track": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "source", "start", "gain"],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "enum": ["bgm", "sfx"]
        },
        "source": {
          "type": "string"
        },
        "start": {
          "type": "number",
          "minimum": 0
        },
        "end": {
          "type": "number",
          "minimum": 0
        },
        "gain": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        }
      }
    },
    "ending_track": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy"],
      "properties": {
        "policy": {
          "enum": ["none", "default", "custom"]
        },
        "source": {
          "type": "string"
        }
      }
    },
    "qa_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visual", "subtitle", "semantic"],
      "properties": {
        "visual": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "no_black_frames": {
              "type": "boolean"
            },
            "no_local_crop_focus": {
              "const": true
            },
            "landscape_width_filled_centered": {
              "type": "boolean"
            },
            "portrait_width_filled": {
              "type": "boolean"
            }
          }
        },
        "subtitle": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "must_not_cover_subject": {
              "type": "boolean"
            },
            "max_lines": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3
            }
          }
        },
        "semantic": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "result_claim_requires_result_asset": {
              "type": "boolean"
            },
            "multi_scene_text_requires_multi_assets": {
              "type": "boolean"
            },
            "module_text_requires_matching_module": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "visual_qa_expectations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "no_black_frame": {
          "type": "boolean"
        },
        "no_local_crop_focus": {
          "const": true
        },
        "subtitle_safe": {
          "type": "boolean"
        },
        "image_count_matches_claim": {
          "type": "boolean"
        }
      }
    },
    "safe_area": {
      "type": "object",
      "additionalProperties": false,
      "required": ["top", "bottom", "left", "right"],
      "properties": {
        "top": {
          "type": "integer",
          "minimum": 0
        },
        "bottom": {
          "type": "integer",
          "minimum": 0
        },
        "left": {
          "type": "integer",
          "minimum": 0
        },
        "right": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "normalized_box": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "y": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "w": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "h": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        }
      }
    },
    "truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "can_claim_real_generation"],
      "properties": {
        "source": {
          "enum": [
            "frontend_registry",
            "cdp_screenshot",
            "cdp_result_capture",
            "gpt_image_layout_optimization",
            "human_curated_case",
            "static_material"
          ]
        },
        "receipt_id": {
          "type": "string"
        },
        "can_claim_real_generation": {
          "type": "boolean"
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ai_verified": {
          "type": "boolean"
        },
        "readable": {
          "type": "boolean"
        },
        "usable_for_video": {
          "type": "boolean"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
