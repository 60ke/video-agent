{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video-agent.local/schemas/material_manifest.schema.json",
  "title": "Video Agent Material Manifest",
  "description": "Long-lived site material library manifest. It records every website screenshot, result image, GPT-prepared keyframe, and evidence asset that can be selected by video planners.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "library_id", "site", "generated_at", "assets"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "library_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "site": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "site_label": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_registry": {
      "$ref": "#/$defs/source_registry"
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/material_asset"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "$defs": {
    "source_registry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": {
          "enum": ["frontend_registry", "manual_manifest", "mixed"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "last_reviewed": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "material_asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id",
        "site",
        "source_level_1",
        "asset_kind",
        "visual_state",
        "aspect",
        "path",
        "display_rule",
        "usage",
        "claims",
        "quality",
        "truth"
      ],
      "properties": {
        "asset_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "site": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "source_level_1": {
          "enum": ["site", "text_to_image", "graphic_ad", "ai_tool", "rendered_effects", "static_case", "shared"]
        },
        "module": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "module_label": {
          "type": "string"
        },
        "route": {
          "type": "string"
        },
        "industry": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "industry_label": {
          "type": "string"
        },
        "scene": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "scene_label": {
          "type": "string"
        },
        "asset_kind": {
          "enum": [
            "site_home",
            "feature_entry",
            "feature_menu",
            "feature_route_page",
            "feature_form_params",
            "generate_callout",
            "generating_state",
            "result_page_evidence",
            "result_image",
            "case_image",
            "gpt_keyframe",
            "cover_candidate"
          ]
        },
        "visual_state": {
          "enum": ["raw", "clean", "callout", "gpt_9x16", "prepared_9x16", "rejected", "archived"]
        },
        "aspect": {
          "enum": ["portrait", "landscape", "square", "nine_by_sixteen", "unknown"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "source_path": {
          "type": "string"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "display_rule": {
          "$ref": "#/$defs/display_rule"
        },
        "usage": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/usage"
          },
          "uniqueItems": true
        },
        "claims": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true,
          "default": []
        },
        "quality": {
          "$ref": "#/$defs/quality"
        },
        "truth": {
          "$ref": "#/$defs/truth"
        },
        "relations": {
          "$ref": "#/$defs/relations"
        },
        "prompt_inputs": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        },
        "callouts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/callout"
          },
          "default": []
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "asset_kind": {
                "const": "result_page_evidence"
              }
            }
          },
          "then": {
            "properties": {
              "usage": {
                "not": {
                  "contains": {
                    "const": "result_showcase"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "asset_kind": {
                "enum": ["result_image", "case_image"]
              }
            }
          },
          "then": {
            "required": ["module_label"],
            "properties": {
              "claims": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "display_rule": {
      "enum": [
        "prepared_9x16",
        "portrait_full_width",
        "landscape_full_width_center",
        "grid_showcase",
        "split_compare"
      ]
    },
    "usage": {
      "enum": [
        "hook",
        "fast_cut",
        "site_intro",
        "feature_entry",
        "process_proof",
        "form_explain",
        "result_showcase",
        "gallery",
        "industry_showcase",
        "multi_feature_showcase",
        "cover",
        "evidence_only"
      ]
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ai_verified", "readable", "usable_for_video"],
      "properties": {
        "ai_verified": {
          "type": "boolean"
        },
        "readable": {
          "type": "boolean"
        },
        "usable_for_video": {
          "type": "boolean"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "can_claim_real_generation"],
      "properties": {
        "source": {
          "enum": [
            "frontend_registry",
            "cdp_screenshot",
            "cdp_result_capture",
            "gpt_image_layout_optimization",
            "human_curated_case",
            "static_material"
          ]
        },
        "receipt_id": {
          "type": "string"
        },
        "source_asset_id": {
          "type": "string"
        },
        "can_claim_real_generation": {
          "type": "boolean"
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "verified_by": {
          "enum": ["cdp", "gpt_image", "human", "script", "unknown"]
        }
      }
    },
    "relations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_asset_id": {
          "type": "string"
        },
        "result_group_id": {
          "type": "string"
        },
        "module_group_id": {
          "type": "string"
        },
        "derived_asset_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "callout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "target_label", "box"],
      "properties": {
        "type": {
          "enum": ["highlight_box", "arrow", "pulse_ring", "label_tag"]
        },
        "target_label": {
          "type": "string"
        },
        "box": {
          "$ref": "#/$defs/normalized_box"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "normalized_box": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "w", "h"],
      "properties": {
        "x": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "y": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "w": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "h": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
